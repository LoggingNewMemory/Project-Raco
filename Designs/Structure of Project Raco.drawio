          <mxGeometry height="170" width="430" x="310" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="eyppIntXDMKMuIVPNFLS-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;b&gt;RSWAP (&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Raco SWAP)&lt;/span&gt;&lt;/b&gt;&lt;div&gt;Put the game on dedicated SWAP space so that it will launch faster next time&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The idea is like Quick Startup on OPlus Game Technology called OSWAP but this time user can do load / unload the apps&lt;/div&gt;" vertex="1">
