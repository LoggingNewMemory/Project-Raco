        <mxCell id="I-TilSuo9_9ndQIc43lT-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Configuration of Raco is stored on&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;/data/ProjectRaco/raco.txt&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="160" x="-830" y="550" as="geometry" />
        </mxCell>
        <mxCell id="I-TilSuo9_9ndQIc43lT-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="The handling of reading is handled by C&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;This way it will come like this if the script need to use the configuration (using if)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;So pretty much like this (workflow)&lt;/div&gt;&lt;div&gt;read config (raco.txt) &amp;gt; Get the key (Example:&amp;nbsp;LITE_MODE) &amp;gt; Execute according what the value is&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="430" x="-660" y="490" as="geometry" />
        </mxCell>
        <mxCell id="I-TilSuo9_9ndQIc43lT-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="&lt;div&gt;&lt;b&gt;Pseudo of Usage of Configuration Files&amp;nbsp;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;[Import the raco.txt]&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (LITE_MODE == 1) then {&lt;/div&gt;&lt;div&gt;*command*&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;else {&lt;/div&gt;&lt;div&gt;*command*&lt;br&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="230" x="-830" y="620" as="geometry" />
        </mxCell>
        <mxCell id="I-TilSuo9_9ndQIc43lT-27" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="&lt;b&gt;Final Structure (Flashed) - /data/adb/modules/ProjectRaco&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;- All compiled related to tweaks will be put on:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;/data/adb/modules/ProjectRaco/Compiled/&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;(Look at next one -&amp;gt;)&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
