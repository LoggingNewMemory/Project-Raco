        <mxCell id="Mku9C3x5ve99xOo_dCDD-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;b&gt;Awaken&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;Max CPUFreq&amp;nbsp;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;cpuinfo_max_freq &amp;gt;&amp;nbsp;scaling_min_freq&lt;/div&gt;&lt;div&gt;&lt;div&gt;cpuinfo_max_freq &amp;gt;&amp;nbsp;scaling_max_freq&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Max GPUFreq&lt;/div&gt;&lt;div&gt;performance misc tweaks&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="210" x="-830" y="910" as="geometry" />
        </mxCell>
        <mxCell id="Mku9C3x5ve99xOo_dCDD-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;b&gt;Balanced&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;CPU MidFreq as minfreq&lt;/u&gt;&lt;/div&gt;&lt;div&gt;cpu mid freq &amp;gt;&amp;nbsp;scaling_min_freq&lt;/div&gt;&lt;div&gt;&lt;div&gt;cpuinfo_max_freq &amp;gt;&amp;nbsp;scaling_max_freq&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;GPU Midfreq as GPU minfreq&lt;/div&gt;&lt;div&gt;balanced misc tweaks&lt;/div&gt;" vertex="1">
