        <mxCell id="I-TilSuo9_9ndQIc43lT-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=default;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Assembly (only arm64) + C Scripts Concept&lt;/b&gt;&lt;div&gt;Do take a note that using shell is &lt;b&gt;PROHIBITED&lt;/b&gt; by any means&lt;/div&gt;" vertex="1">
