        <mxCell id="I-TilSuo9_9ndQIc43lT-22" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;b&gt;Configuration Files&lt;/b&gt;&lt;div&gt;&lt;b&gt;And Final Structure&lt;/b&gt;&lt;/div&gt;" vertex="1">
