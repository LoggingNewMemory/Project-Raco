        <mxCell id="eyppIntXDMKMuIVPNFLS-19" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="OOM Adjustment so that the game will not get killed" vertex="1">
          <mxGeometry height="110" width="115" x="-555" y="2070" as="geometry" />
        </mxCell>
        <mxCell id="eyppIntXDMKMuIVPNFLS-22" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Do Note:&lt;div&gt;- vm.swappiness will need to set into 100&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;-&amp;nbsp;Adjust vm.min_free_kbytes so Android doesn&#39;t panic and trigger a memory kill before it has a chance to swap the game out properly.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="255" x="-355" y="1700" as="geometry" />
        </mxCell>
        <mxCell id="eyppIntXDMKMuIVPNFLS-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;On Exit Game&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;do kill -STOP &amp;lt;pid&amp;gt; so that the game will pauses&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Saving CPU usage and RAM (Or Resources)&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="230" x="-71.47999999999999" y="2030" as="geometry" />
        </mxCell>
        <mxCell id="eyppIntXDMKMuIVPNFLS-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;On Resume Game&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;do kill -CONT &amp;lt;pid&amp;gt; so that the game will Resume&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;pulls the pages from RSWAP back into RAM&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="230" x="-71.47999999999999" y="2150" as="geometry" />
        </mxCell>
