        <mxCell id="I-TilSuo9_9ndQIc43lT-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="C will handle:&lt;div&gt;- Handle the logic&lt;/div&gt;&lt;div&gt;- Accept the &lt;b&gt;Tweak &lt;/b&gt;and &lt;b&gt;Kakangku&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Example:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;tweak /sys/pnpmgr/mwn 1&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;kakangku /proc/gpufreq/gpufreq_opp_freq&amp;nbsp;&lt;/b&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;So Basically the structure that the C accepts is&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;tweak [path] [value]&lt;/div&gt;&lt;div style=&quot;&quot;&gt;kakangku [path] [value]&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="260" x="-510" y="270" as="geometry" />
        </mxCell>
        <mxCell id="I-TilSuo9_9ndQIc43lT-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;Kakangku (Case If No Need Permission to Set 444)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Works like this&lt;div&gt;1. Check if file exist&lt;/div&gt;&lt;div&gt;2. Change Permission to 644&lt;/div&gt;&lt;div&gt;3. Write the value&lt;/div&gt;&lt;/div&gt;" vertex="1">
