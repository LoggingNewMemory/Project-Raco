        <mxCell id="I-TilSuo9_9ndQIc43lT-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="&lt;div&gt;&lt;b&gt;Pseudo of Usage of Configuration Files&amp;nbsp;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;[Import the raco.txt]&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (LITE_MODE == 1) then {&lt;/div&gt;&lt;div&gt;*command*&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;else {&lt;/div&gt;&lt;div&gt;*command*&lt;br&gt;}&lt;/div&gt;" vertex="1">
