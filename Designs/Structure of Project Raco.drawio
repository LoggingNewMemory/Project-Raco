          <mxGeometry height="100" width="360" x="-590" y="730" as="geometry" />
        </mxCell>
        <mxCell id="I-TilSuo9_9ndQIc43lT-29" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="The service.sh and post-fs-data.sh will be linked with the compiled binary&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;as for the location it will be on&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;&lt;b&gt;/data/adb/modules/ProjectRaco/CoreSys/&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Example on service.sh&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;span style=&quot;text-align: left;&quot;&gt;/data/adb/modules/ProjectRaco/&lt;/span&gt;&lt;span style=&quot;text-align: left;&quot;&gt;CoreSys&lt;/span&gt;&lt;span style=&quot;text-align: left;&quot;&gt;/&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;raco_service&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;span style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;&quot;&gt;DO CHECK! (On customize.sh):&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;&quot;&gt;Set the permission of The Binaries (CoreSys and Compiled)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;&quot;&gt;chmod&amp;nbsp;&lt;/span&gt;755&lt;/div&gt;" vertex="1">
          <mxGeometry height="340" width="330" x="-220" y="490" as="geometry" />
